{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas Scenario Fixture",
  "type": "object",
  "required": [
    "fixtureId",
    "name",
    "asOfDate",
    "assumptionVersion",
    "formulaVersion",
    "question",
    "inputs",
    "expected",
    "tolerances",
    "references"
  ],
  "properties": {
    "fixtureId": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1 },
    "asOfDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "assumptionVersion": { "type": "string", "minLength": 1 },
    "formulaVersion": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "inputs": { "type": "object" },
    "expected": {
      "type": "object",
      "required": ["metrics", "warnings", "recommendation"],
      "properties": {
        "metrics": { "type": "object" },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "recommendation": {
          "type": "object",
          "required": ["status", "score", "explanation", "warningReferences"],
          "properties": {
            "status": { "type": "string", "minLength": 1 },
            "score": { "type": "number" },
            "explanation": { "type": "string", "minLength": 1 },
            "warningReferences": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "tolerances": { "type": "object" },
    "references": { "type": "array", "items": { "type": "string" } }
  }
}

{
  "name": "atlas-enterprise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:knowledge": "node frontend/scripts/build-knowledge-index.mjs",
    "validate:frontend": "node frontend/scripts/validate-frontend.mjs",
    "validate:pwa": "node frontend/scripts/validate-pwa.mjs",
    "validate:offline": "node frontend/scripts/validate-offline-cache.mjs",
    "validate:formula-registry": "node simulator/scripts/validate-formula-registry.mjs",
    "validate:fixtures": "node simulator/scripts/validate-fixtures.mjs",
    "generate:dashboard-fixtures": "node frontend/scripts/generate-dashboard-fixtures.mjs",
    "report:visual": "node frontend/scripts/generate-visual-report.mjs",
    "simulator:run": "node simulator/scripts/run-simulator.mjs",
    "validate:simulator": "node simulator/scripts/validate-simulator-output.mjs",
    "visual:screenshots": "node frontend/scripts/capture-playwright-screenshots.mjs",
    "validate": "npm run validate:frontend && npm run validate:formula-registry && npm run validate:fixtures && npm run validate:pwa && npm run validate:offline && npm run validate:simulator",
    "build": "npm run build:knowledge",
    "dev": "npm run build:knowledge"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}

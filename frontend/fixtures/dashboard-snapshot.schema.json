{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas Dashboard Snapshot",
  "type": "object",
  "required": ["schemaVersion", "snapshotId", "label", "asOfDate", "currency", "sourceFixture", "metrics", "scenarios", "actions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "const": "dashboard-snapshot.v2" },
    "snapshotId": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "asOfDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "currency": { "type": "string", "enum": ["TWD", "USD"] },
    "sourceFixture": { "type": "string", "minLength": 1 },
    "metrics": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["label", "value", "detail", "formulaIds"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" },
          "detail": { "type": "string" },
          "formulaIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^FORM-[A-Z0-9-]+$" }
          }
        }
      }
    },
    "scenarios": { "type": "array", "minItems": 3 },
    "actions": { "type": "array", "minItems": 3, "items": { "type": "string" } }
  }
}

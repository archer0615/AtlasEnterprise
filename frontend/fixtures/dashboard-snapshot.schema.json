{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas Dashboard Snapshot",
  "type": "object",
  "required": ["snapshotId", "label", "asOfDate", "currency", "sourceFixture", "metrics", "scenarios", "actions"],
  "properties": {
    "snapshotId": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "asOfDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "sourceFixture": { "type": "string", "minLength": 1 },
    "metrics": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["label", "value", "detail"],
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "scenarios": { "type": "array", "minItems": 3 },
    "actions": { "type": "array", "minItems": 3, "items": { "type": "string" } }
  }
}
